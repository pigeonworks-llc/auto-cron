# auto-cron initial config (chezmoi template、deploy 後 user 編集前提)
#
# Cron job lifecycle commands are 1-line `make <target>` calls; the actual
# logic lives in the target repo (dotfiles / docs) under scripts/ci/*.sh,
# wired through makefiles/cron-jobs.mk (dotfiles) or Makefile (docs).
# This keeps shell out of yaml and lets a future GitHub Actions workflow
# reuse the exact same target via `run: make <name>`.
global:
  maxConcurrentJobs: 4
  groupMax:
    renovate: 1

jobs:
  - name: auto-forge-serve
    lifecycle: service
    command:
      - sops
      - exec-env
      - {{ .chezmoi.homeDir }}/.config/secrets/github.sops.env
      - bun {{ .chezmoi.homeDir }}/src/forgejo.localhost/pigeonworks-llc/auto-forge/src/main/bin.ts serve
    env:
      AUTO_FORGE_DATA_DIR: {{ .chezmoi.homeDir }}/.local/share/auto-forge
    restart:
      backoffMs: [1000, 5000, 30000]
      resetAfterSec: 60
    notify:
      onFailure: digest

  # Phase K wave 1 #1: migrate from Jenkins dotfiles/bats-full
  # Source: dotfiles makefiles/cron-jobs.mk → scripts/ci/bats-full.sh
  # Schedule: Jenkins 側 `H(30-59) 3 * * *` を croner 互換に固定化 (cron 5-field)
  - name: dotfiles-bats-full
    schedule:
      kind: cron
      expr: "45 3 * * *"
      timezone: Asia/Tokyo
    command:
      - make
      - -C
      - {{ .chezmoi.homeDir }}/src/forgejo.localhost/shunichi-ikebuchi/dotfiles
      - bats-full
    env:
      CI: "true"
    retry:
      maxAttempts: 1
      backoffMs: []
    notify:
      onFailure: immediate

  # Phase K wave 1 #3: migrate from Jenkins dotfiles/renovate (Docker → bun x renovate)
  # Source: dotfiles makefiles/cron-jobs.mk → scripts/ci/renovate.sh
  # Schedule: renovate.json schedule "after 9am on monday" = `0 9 * * 1` Asia/Tokyo
  # Concurrency: group renovate (globalConcurrency.groupMax.renovate=1 で 1 並列固定)
  # Secret: RENOVATE_TOKEN / FORGEJO_TOKEN は daemon の env 経由 (launchd plist で sops exec-env)
  - name: dotfiles-renovate
    schedule:
      kind: cron
      expr: "0 9 * * 1"
      timezone: Asia/Tokyo
    command:
      - make
      - -C
      - {{ .chezmoi.homeDir }}/src/forgejo.localhost/shunichi-ikebuchi/dotfiles
      - renovate
    env:
      CI: "true"
    concurrency:
      onOverlap: skip
      group: renovate
    retry:
      maxAttempts: 1
      backoffMs: []
    notify:
      onFailure: immediate

  # Phase K wave 1 #2: migrate from Jenkins docs/link-check
  # Source: docs Makefile lint-link-ci → scripts/ci/lint-link-ci.sh
  # Schedule: Jenkins 側 `H 3 * * *` (UTC) = 12:00 JST 固定
  # Notify: digest (auto-cron 朝集約)、 strict exit code は make target 側で担保
  - name: docs-link-check
    schedule:
      kind: cron
      expr: "0 12 * * *"
      timezone: Asia/Tokyo
    command:
      - bash
      - -lc
      - |
        set -euo pipefail
        cd {{ .chezmoi.homeDir }}/src/forgejo.localhost/shunichi-ikebuchi/docs
        npm install --no-audit --no-fund --silent
        make lint-link-ci
    env:
      CI: "true"
    retry:
      maxAttempts: 1
      backoffMs: []
    notify:
      onFailure: digest
