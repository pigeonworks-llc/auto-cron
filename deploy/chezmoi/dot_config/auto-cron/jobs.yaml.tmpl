# auto-cron initial config (chezmoi template、deploy 後 user 編集前提)
global:
  maxConcurrentJobs: 4
  groupMax:
    renovate: 1

jobs:
  - name: auto-forge-serve
    lifecycle: service
    command:
      - sops
      - exec-env
      - {{ .chezmoi.homeDir }}/.config/secrets/github.sops.env
      - bun {{ .chezmoi.homeDir }}/src/forgejo.localhost/pigeonworks-llc/auto-forge/src/main/bin.ts serve
    env:
      AUTO_FORGE_DATA_DIR: {{ .chezmoi.homeDir }}/.local/share/auto-forge
    restart:
      backoffMs: [1000, 5000, 30000]
      resetAfterSec: 60
    notify:
      onFailure: digest

  # Phase K wave 1 #1: migrate from Jenkins dotfiles/bats-full
  # Source: Jenkinsfile.bats-full @ origin/main (sh stage は find ... bats --jobs 8 1 行)
  # Schedule: Jenkins 側 `H(30-59) 3 * * *` を croner 互換に固定化 (cron 5-field、 H symbol 非対応)
  # Shadow-run: Jenkins 側 cron は当面残す (1 週間 stable 確認後 jobs.yaml から削除)
  - name: dotfiles-bats-full
    schedule:
      kind: cron
      expr: "45 3 * * *"
      timezone: Asia/Tokyo
    command:
      - bash
      - -lc
      - |
        set -euo pipefail
        cd {{ .chezmoi.homeDir }}/src/forgejo.localhost/shunichi-ikebuchi/dotfiles
        find . -name "executable_*" -type f ! -path "./.git/*" -exec chmod +x {} +
        find . -name "*.bats" -type f \
          ! -path "./.git/*" \
          ! -path "./node_modules/*" \
          ! -path "./archive/*" \
          -print0 | xargs -0 -r bats --jobs 8
    env:
      CI: "true"
    retry:
      maxAttempts: 1
      backoffMs: []
    notify:
      onFailure: immediate

  # Phase K wave 1 #3: migrate from Jenkins dotfiles/renovate (Docker → bun x renovate)
  # Source: Jenkinsfile.renovate @ dotfiles origin/main (docker run renovate/renovate)
  # Switch: Docker image → `bun x renovate@latest` 直起動 (plan: container 不使用方針)
  # Schedule: renovate.json schedule "after 9am on monday" = `0 9 * * 1` Asia/Tokyo 固定
  # Concurrency: group renovate (globalConcurrency.groupMax.renovate=1 で 1 並列固定済)
  # Secret: RENOVATE_TOKEN は daemon の env 経由 (sops/forgejo.sops.env を launchd plist で
  #   load 想定、 暫定で FORGEJO_TOKEN を再利用、 専用 renovate-bot user は別 task)
  - name: dotfiles-renovate
    schedule:
      kind: cron
      expr: "0 9 * * 1"
      timezone: Asia/Tokyo
    command:
      - bash
      - -lc
      - |
        set -euo pipefail
        cd {{ .chezmoi.homeDir }}/src/forgejo.localhost/shunichi-ikebuchi/dotfiles
        export RENOVATE_PLATFORM=forgejo
        export RENOVATE_ENDPOINT=http://forgejo.localhost/api/v1
        export RENOVATE_GIT_URL=endpoint
        export RENOVATE_AUTODISCOVER=false
        export RENOVATE_ONBOARDING=false
        export RENOVATE_REPOSITORIES=shunichi-ikebuchi/dotfiles
        export RENOVATE_GIT_AUTHOR="Renovate Bot <renovate@pigeonworks.local>"
        export RENOVATE_TOKEN="${RENOVATE_TOKEN:-${FORGEJO_TOKEN:-}}"
        if [ -z "$RENOVATE_TOKEN" ]; then
          echo "RENOVATE_TOKEN / FORGEJO_TOKEN unset — daemon env wiring incomplete (see deploy launchd plist)" >&2
          exit 1
        fi
        bun x renovate@latest
    env:
      CI: "true"
    concurrency:
      onOverlap: skip
      group: renovate
    retry:
      maxAttempts: 1
      backoffMs: []
    notify:
      onFailure: immediate

  # Phase K wave 1 #2: migrate from Jenkins docs/link-check
  # Source: Jenkinsfile.link-check @ docs origin/main
  # - Setup: npm install (idempotent)
  # - Link Check (full repo): find docs/*.md | xargs npx markdown-link-check -q -c .markdown-link-check.json
  # Schedule: Jenkins 側 `H 3 * * *` (UTC) = 12:00 JST 固定。 cron 5-field 表記。
  # Notify: warn-only (Jenkins では unstable、 PR block しない)、 auto-cron では digest 経路で朝集約。
  # Shadow-run: Jenkins 側 cron は当面残す。
  - name: docs-link-check
    schedule:
      kind: cron
      expr: "0 12 * * *"
      timezone: Asia/Tokyo
    command:
      - bash
      - -lc
      - |
        set -euo pipefail
        cd {{ .chezmoi.homeDir }}/src/forgejo.localhost/shunichi-ikebuchi/docs
        npm install --no-audit --no-fund --silent
        FAILED=0
        TOTAL=0
        while IFS= read -r f; do
          TOTAL=$((TOTAL+1))
          if ! npx markdown-link-check -q -c .markdown-link-check.json "$f"; then
            FAILED=$((FAILED+1))
          fi
        done < <(find docs -name '*.md' -type f)
        echo "files checked: $TOTAL, failed: $FAILED"
        test "$FAILED" -eq 0
    env:
      CI: "true"
    retry:
      maxAttempts: 1
      backoffMs: []
    notify:
      onFailure: digest
